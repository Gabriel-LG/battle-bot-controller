er(NumberFormat.Int8BE, 3, buttons);\n        radio.sendBuffer(buffer);\n    }\n\n    //% block\n    export function initController(id: number): void {\n        joystickbit.initJoystickBit();\n        if (!started) control.setInterval(sendUpdate, 20, control.IntervalMode.Interval)\n        radio.setGroup(0);\n        radio.setFrequencyBand(id * 5);\n        started = true;\n    }\n}\n"}]},{"timestamp":1778837717856,"editorVersion":"8.0.22","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":3790,"diffs":[[1,"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"/BdCpy*:rN.)s@dPCK-{\">id</variable></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"><statement name=\"HANDLER\"><block type=\"variables_set\"><field name=\"VAR\" id=\"/BdCpy*:rN.)s@dPCK-{\">id</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow></value><next><block type=\"controller_initController\"><value name=\"id\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"/BdCpy*:rN.)s@dPCK-{\">id</field></block></value><next><block type=\"device_show_number\"><value name=\"number\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"variables_get\"><field name=\"VAR\" id=\"/BdCpy*:rN.)s@dPCK-{\">id</field></block></value><next><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">1000</field></shadow></value><next><block type=\"device_clear_display\"></block></next></block></next></block></next></block></next></block></statement></block><block type=\"device_forever\" x=\"447\" y=\"39\"><statement name=\"HANDLER\"><block type=\"device_clear_display\"><next><block type=\"device_plot\"><value name=\"x\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"4\" label=\"X\" precision=\"1\"></mutation><field name=\"SLIDER\">0</field></shadow><block type=\"m